# editorconfig.org
root = true

[**]
end_of_line = lf
indent_style = space
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 4

[packages/**.php]
indent_style = tab

[tests/**.php]
indent_style = space

[*.{css,js,json,jsonc,ts,yaml,yml,scss,toml}]
indent_size = 2

[.*rc]
indent_size = 2

[bun.lock]
indent_size = 2

[composer.json]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
