# --- Core Versions ---
# PHP version (8.1, 8.2, 8.3, 8.4)
PHP_VERSION=8.4
# WordPress version (5.9 through 6.9 supported by init-wp.sh)
WP_VERSION=6.9

# --- Advanced ---
# Set to 1 to wipe volumes/wordpress and perform a fresh download on next start
WP_RESET=0

# --- Port Mapping ---
# Local ports for accessing services
FORWARD_WEB_PORT=8080
FORWARD_MAILPIT_PORT=8025
FORWARD_DB_PORT=3306

# --- Database Credentials ---
DB_USER=wordpress
DB_PASS=secret
DB_NAME=wordpress

# --- WordPress Site Configuration ---
# Public URL of the site
SITE_URL="http://localhost:${FORWARD_WEB_PORT}"
SITE_TITLE="WordPress Local"
SITE_TIMEZONE=Asia/Jakarta
# Set to 1 to enable WP_DEBUG
SITE_DEBUG=0
SITE_ADMIN_USER=admin
SITE_ADMIN_PASS=secret
SITE_ADMIN_EMAIL=admin@example.com

# --- Plugins & Themes ---
# Comma-separated list of official slugs to install from WordPress.org
SITE_PLUGINS=blocksy-companion,contact-form-7
SITE_THEMES=blocksy
# Theme to activate by default (can be local or official)
SITE_DEFAULT_THEME=custom-theme

# --- Multisite Network ---
# Set to 1 to automatically convert to a subfolder network
MULTISITE_ENABLED=0

# --- WooCommerce Configuration ---
# These are only applied if 'woocommerce' is in SITE_PLUGINS
WC_STORE_ADDRESS="Jl. Example No. 123"
WC_STORE_CITY="Batang"
WC_DEFAULT_COUNTRY="ID:JT"
WC_CURRENCY="IDR"
WC_STORE_POSTCODE="12345"
WC_WEIGHT_UNIT=kg
WC_DIMENSION_UNIT=cm
WC_PRICE_THOUSAND_SEP=.
WC_PRICE_DECIMAL_SEP=,
WC_PRICE_DECIMAL_NUM=0
