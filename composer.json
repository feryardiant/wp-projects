{
    "name": "feryardiant/wordpress-env",
    "description": "A zero-config, Docker-based local environment designed for rapid evaluation of WordPress themes and plugins.",
    "keywords": [ "composer", "wordpress", "boilerplate" ],
    "homepage": "https://github.com/feryardiant/wp-env/",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Fery Wardiyanto",
            "email": "ferywardiyanto@gmail.com"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "git@github.com:feryardiant/wp-env.git"
        }
    ],
    "scripts": {
        "format": [
            "@format:packages",
            "@format:tests"
        ],
        "format:packages": [
            "phpcbf --standard=packages/phpcs.xml"
        ],
        "format:tests": [
            "phpcbf --standard=tests/phpcs.xml"
        ],
        "lint": [
            "@lint:packages",
            "@lint:tests"
        ],
        "lint:packages": [
            "phpcs --standard=packages/phpcs.xml"
        ],
        "lint:tests": [
            "phpcs --standard=tests/phpcs.xml"
        ],
        "test": [
            "phpunit --coverage-text"
        ]
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "brain/monkey": "^2.7",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "mockery/mockery": "^1.6",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.13",
        "wikimedia/composer-merge-plugin": "^2.1",
        "wp-cli/config-command": "^2.4",
        "wp-cli/core-command": "^2.1",
        "wp-cli/dist-archive-command": "^3.1",
        "wp-cli/entity-command": "^2.8",
        "wp-cli/extension-command": "^2.1",
        "wp-cli/i18n-command": "^2.7",
        "wp-cli/wp-cli": "^2.12",
        "wp-coding-standards/wpcs": "^3.3"
    },
    "autoload-dev": {
        "psr-4": {
            "Fixtures\\": "tests/fixtures",
            "UnitTests\\": "tests/units",
            "IntegrationTests\\": "tests/integrations"
        }
    },
    "extra": {
        "merge-plugin": {
            "include": [
                "packages/*/composer.json"
            ]
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}
