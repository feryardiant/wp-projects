{
  "name": "@feryardiant/wordpress-env",
  "type": "module",
  "private": true,
  "license": "MIT",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "format": "biome format --write",
    "lint": "biome check",
    "postinstall": "if [ -z \"$CI\" ]; then simple-git-hooks; fi"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "1.3.10",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1"
  },
  "overrides": {
    "@types/node": "24.9.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged --allow-empty"
  },
  "lint-staged": {
    "*.{css,jsonc,ts}": [
      "biome format --write --no-errors-on-unmatched"
    ],
    "packages/**/*.php": [
      "sh -c 'composer format:packages -- \"$@\"; [ \"$?\" -eq 0 ] || [ \"$?\" -eq 1 ]' --"
    ],
    "tests/**/*.php": [
      "sh -c 'composer format:tests -- \"$@\"; [ \"$?\" -eq 0 ] || [ \"$?\" -eq 1 ]' --"
    ],
    "{package,tsconfig}.json": [
      "biome format --write --no-errors-on-unmatched"
    ]
  }
}
